            new Category("Science", "https://i.ytimg.com/vi/V7RrYe8VVKs/maxresdefault.jpg"),
            new Category("History", "https://assets.genially.com/s3fs-public/History%20quizen.png?VersionId=Wn9knTDgFtewm9LhOgsgyYD7zqmUa.rH"),
